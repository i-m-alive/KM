# Postgres connection string (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg://naviknow:naviknow@localhost:5433/naviknow

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# AWS / Bedrock - assumes credentials are already configured via the standard
# AWS credential chain (env vars, ~/.aws/credentials, SSO, or an instance role).
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Storage
OUTPUTS_DIR=outputs

# CORS - comma-separated list is not supported by pydantic list parsing from
# plain env vars; if you need more than one origin, set this as a JSON array.
CORS_ORIGINS=["http://localhost:5173"]

# Cookies
REFRESH_COOKIE_NAME=naviknow_refresh_token
COOKIE_SECURE=false

# If set, this email is (re-)promoted to the 'admin' role on every backend
# startup. Set it to your own signup email, restart the backend, and you'll
# have an admin account to run the Admin Panel with.
ADMIN_BOOTSTRAP_EMAIL=
